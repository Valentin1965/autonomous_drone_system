# /etc/rover/rover-cv.env
# Env для systemd unit rover-cv.service (RPi companion).

# Репозиторій
SYSTEM_CONFIG=config/system_rpi.yaml
CV_CONFIG=config/cv_rpi.yaml
MAVLINK_PROFILE=px4

# Джерело відео для CV (див. cv/tracker.py: oakd/webcam/rtsp/...)
CV_SOURCE=oakd

# Якщо використовуєте окремий venv/інший python — краще виправити ExecStart у unit.
